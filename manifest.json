{
  "manifest_version": 3,
  "name": "Mundial 2026 Tracker",
  "version": "1.0.0",
  "description": "Resultados, marcadores en vivo y tabla de grupos del Mundial 2026 — sin cambiar de pestaña.",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Mundial 2026"
  },

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },

  "permissions": [
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "https://site.api.espn.com/*"
  ],

  "minimum_chrome_version": "88"
}
